{
  "name": "@namelessaffirmation/na-web",
  "version": "1.0.0",
  "description": "The Official NamelessAffirmation Web Project.",
  "scripts": {
    "start": "npm run serve:local",
    "serve:local": "NODE_ENV=development npx tsc-watch --outDir ./dist --onSuccess \"node -r dotenv/config ./dist/main.js\"",
    "build": "npm run clean && npm run compile",
    "clean": "rm -rf dist",
    "compile": "npx tsc"
  },
  "license": "MIT",
  "dependencies": {
    "bullmq": "^3.13.0",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "ioredis": "^5.3.2",
    "tsyringe": "^4.7.0",
    "typeorm": "^0.3.15"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.1.0",
    "dotenv": "^16.0.3",
    "prettier": "^2.8.8",
    "reflect-metadata": "^0.1.13",
    "ts-node": "^10.9.1",
    "tsc-watch": "^6.0.4",
    "typescript": "^5.0.4"
  }
}
